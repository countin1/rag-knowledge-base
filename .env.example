# RAG Knowledge Base 配置文件
# 复制此文件为 .env 并填入你的配置

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_api_key_here

# 可选: 自定义 API 地址
# LLM_BASE_URL=https://api.deepseek.com

# 可选: 自定义模型
# LLM_MODEL=deepseek-chat

# 可选: Embedding 模型
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_DEVICE=cpu

# 可选: 分块参数
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50

# 可选: 检索参数
# TOP_K=5
# SIMILARITY_THRESHOLD=0.3
